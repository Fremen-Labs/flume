# ==========================================
# Flume Deployment & Architecture Config
# ==========================================

# ------------------------------------------
# Local LLM Providers & Routing
# ------------------------------------------
# Ensure the base URLs point directly to the API endpoint of your local models.
# For Docker environments, 'host.docker.internal' natively routes back to your host machine's API.
# For Linux environments where 'host.docker.internal' fails silently, override this to your host IP or docker0 gateway (e.g. 172.17.0.1)
LOCAL_LLM_HOST=host.docker.internal
LOCAL_EXO_BASE_URL=http://${LOCAL_LLM_HOST}:52415/v1
LOCAL_OLLAMA_BASE_URL=http://${LOCAL_LLM_HOST}:11434/v1

# ------------------------------------------
# Worker Engine / Auto-Start Logic
# ------------------------------------------
# Determines how many local AI workers should securely spawn on boot.
# Default is 1. Memory constraints (via 'sysctl -n hw.memsize' on Mac) may cap this dynamically.
FLUME_AUTO_START_WORKERS=1

# ------------------------------------------
# Dashboard Telemetry & Networking
# ------------------------------------------
# The port mapping for the FastAPI backend and local React Vite frontend telemetry stream.
DASHBOARD_PORT=8765

# ------------------------------------------
# Advanced Telemetry (Optional)
# ------------------------------------------
# FLUME_DEBUG_LOGGING=true
# DISABLE_EXPERIMENTAL_AGENTS=false

# ==========================================
# Gitflow: integration branch & PR lifecycle
# ==========================================
# Strategy for shared branches. `story` creates ONE long-lived branch per story
# that every task under that story commits into. `task` restores legacy
# one-branch-per-leaf-task behavior (much noisier).
# FLUME_BRANCH_SCOPE=story
#
# When to open a pull request into develop.
#   story = single PR opened when the last task under a story is approved
#           (fewer, fatter PRs; default in docker-compose)
#   task  = PR per task (legacy behavior)
# FLUME_AUTO_PR_SCOPE=story
#
# On startup, ensure the integration branch (`develop` by default) exists on the
# remote; new feature branches are always cut from it. Disable only if you
# manage the integration branch out-of-band. Accepts 0/1, true/false.
# FLUME_ENSURE_INTEGRATION_BRANCH=1
#
# After a PR is merged into the integration branch, delete the feature branch
# on the remote. Prevents orphan/long-tail branches. Accepts 0/1, true/false.
# FLUME_DELETE_REMOTE_BRANCH_AFTER_MERGE=1

# ==========================================
# Concurrency / WIP limits (per project)
# ==========================================
# These values seed every project's `concurrency` block on creation and can be
# overridden per-project in the project doc. Setting any to 0 means unlimited
# (restores legacy behavior). Setting an env override forces the value
# globally and ignores per-project config.
#
# Hard cap on simultaneous running+review implementer tasks per repo. Keeps the
# work linear instead of fanning out and causing merge conflicts.
# FLUME_MAX_RUNNING_PER_REPO=2
#
# Soft cap on how many tasks can sit in `ready` per repo at a time. The PM
# dispatcher stops promoting new tasks once this is reached.
# FLUME_MAX_READY_PER_REPO=4
#
# Number of stories under one feature that can advance in parallel. 1 = fully
# serialized per feature.
# FLUME_STORY_PARALLELISM=1
#
# Serialize PR→develop merges per repo — only one integration merge in flight at
# a time. Set to 0/false to allow parallel merges (risk: interleaved rebases).
# FLUME_SERIALIZE_INTEGRATION_MERGE=1

# ==========================================
# Autonomy sweeps (dashboard background loops)
# ==========================================
# Master switch for the autonomy loop that runs parent-revival, stuck-task
# recovery, plan scanning, branch garbage-collection, and PR reconciliation.
# FLUME_AUTONOMY_ENABLED=1
#
# Base tick interval for the autonomy loop. Individual sweeps honor their own
# intervals below but are never run more often than this.
# FLUME_AUTONOMY_INTERVAL_SEC=60
#
# --- Parent revival: revive parent stories/features whose children finished ---
# Sweep period, lookback window, and max rows per tick.
# FLUME_PARENT_REVIVAL_INTERVAL_SEC=90
# FLUME_PARENT_REVIVAL_LOOKBACK_MIN=180
# FLUME_PARENT_REVIVAL_MAX=25
#
# --- Stuck-task recovery: release claims on tasks whose worker went silent ---
# Mark a claim stale after FLUME_STUCK_TASK_MINUTES without progress; at most
# FLUME_STUCK_TASK_MAX rows per tick; up to FLUME_STUCK_TASK_RETRY_CAP recoveries
# before the task is escalated rather than requeued.
# FLUME_STUCK_TASK_INTERVAL_SEC=120
# FLUME_STUCK_TASK_MINUTES=25
# FLUME_STUCK_TASK_MAX=25
# FLUME_STUCK_TASK_RETRY_CAP=3
#
# --- Plan scan: nudge plans whose execution has gone quiet ---
# Run at most every FLUME_PLAN_SCAN_INTERVAL_SEC; a given plan is nudged at
# most once per FLUME_PLAN_SCAN_COOLDOWN_MIN.
# FLUME_PLAN_SCAN_INTERVAL_SEC=600
# FLUME_PLAN_SCAN_COOLDOWN_MIN=60
#
# --- Branch GC: delete orphan remote feature branches ---
# Tasks in terminal status with a recorded branch and no remote_branch_deleted
# flag get their branch removed (protected branches and shared story scopes
# are skipped).
# FLUME_BRANCH_GC_INTERVAL_SEC=180
# FLUME_BRANCH_GC_MAX_PER_TICK=50
#
# --- PR reconcile: sync GitHub PR state + auto-rebase dirty PRs ---
# Clean PRs are merged; dirty PRs have the integration branch merged in locally
# and the result pushed; drift (e.g. tasks whose PR is already merged on GH) is
# healed back into ES.
# FLUME_PR_RECONCILE_INTERVAL_SEC=120
# FLUME_PR_RECONCILE_MAX_PER_TICK=20

# ==========================================
# Auto-unblocker (LLM-driven recovery of blocked tasks)
# ==========================================
# Master switch for the auto-unblocker daemon. When enabled, blocked tasks that
# have sat past FLUME_AUTO_UNBLOCK_GRACE_SEC are fed to an LLM to propose a
# recovery action (up to FLUME_AUTO_UNBLOCK_MAX attempts per task).
# FLUME_AUTO_UNBLOCK_ENABLED=1
# FLUME_AUTO_UNBLOCK_INTERVAL_SEC=180
# FLUME_AUTO_UNBLOCK_GRACE_SEC=120
# FLUME_AUTO_UNBLOCK_MAX=3
# FLUME_AUTO_UNBLOCK_BATCH=10
# FLUME_AUTO_UNBLOCK_LLM_TIMEOUT=45

# ==========================================
# Implementer agent
# ==========================================
# Maximum iterations the implementer agent will spend on a single task before
# the loop is force-closed and the task returned for reviewer triage.
# FLUME_IMPLEMENTER_MAX_ITERATIONS=30

# ==========================================
# Loop termination: tester / reviewer / bug recursion
# ==========================================
# Hard caps that guarantee every plan terminates. When any cap is exceeded the
# offending task is moved to `blocked` with `needs_human=true` so a person can
# intervene instead of the platform burning cycles. Counters reset when a task
# is approved.
#
# Maximum recursion depth for the tester -> bug task chain. Depth 0 is the
# original task, depth 1 is `bug-task-*-*`, depth 2 is `bug-bug-task-*-*-*`,
# etc. Set to 0 to disable the cap (not recommended). Default: 2.
# FLUME_MAX_BUG_DEPTH=2
#
# Maximum times the tester can reject the same task before it is escalated to
# a human instead of spawning another bug task. Default: 3.
# FLUME_MAX_TESTER_REJECTIONS=3
#
# Maximum times the reviewer can return `changes_requested` on the same task
# before it is escalated to a human instead of re-queueing the implementer.
# This prevents language-mismatch / mis-decomposition ping-pong loops.
# Default: 3.
# FLUME_MAX_REVIEWER_REWORK=3
#
# Cap on tester->reviewer handoff retries when the reviewer never claims the
# handoff (crash, claim bug, LLM outage). Default: 5.
# FLUME_TESTER_RETRY_CAP=5
#
# Cap on consecutive unresolvable reviewer verdicts before blocking the task
# for manual inspection. Default: 3.
# FLUME_REVIEWER_BLOCK_CAP=3
#
# Cap on abnormal implementer handler exits (missing binaries like `go`,
# path-traversal halts, kill-switch aborts, uncaught exceptions) before the
# task is escalated instead of being re-queued forever. Default: 3.
# FLUME_MAX_IMPLEMENTER_EXCEPTIONS=3

# ==========================================
# Orphan heal sweep (routes stuck status/owner mismatches)
# ==========================================
# A task in `status=ready + owner=reviewer` (or similar mismatched pair) is
# unreachable because implementer workers only claim ready+implementer and
# reviewer/tester workers only claim `status=review`. This sweep finds those
# orphans every tick and routes them to the correct status based on owner —
# or blocks them if any loop cap has already been exceeded.
# FLUME_ORPHAN_HEAL_INTERVAL_SEC=30
# FLUME_ORPHAN_HEAL_MAX_PER_TICK=50

# ==========================================
# Concurrency / serial merge mode
# ==========================================
# The default compose file sets these to 1, which means "one feature branch
# in flight per repo at a time". That avoids the multi-branch → everyone
# merges → conflict-cascade pattern you get when several tasks are cut from
# the same `develop` HEAD and then race to merge.
#
# Raise them (or unset) to allow parallel branches:
#   FLUME_MAX_READY_PER_REPO=1        # leaf tasks staged as `ready`
#   FLUME_MAX_RUNNING_PER_REPO=1      # tasks in running+review+blocked-with-branch
#   FLUME_STORY_PARALLELISM=1         # stories progressing in parallel per feature
#   FLUME_SERIALIZE_INTEGRATION_MERGE=1  # serialize PR→develop merges
#
# Key semantic change: the WIP counters include tasks in `blocked` state that
# still have an unmerged branch (e.g. awaiting pr_reconcile rebase). Those
# tasks still own a branch, so they must occupy a WIP slot — otherwise the
# next ready task gets promoted and creates yet another branch on top.

# ==========================================
# Frontend asset seeding
# ==========================================
# The dashboard container normally leaves the host-mounted frontend `dist/`
# alone so your locally-built UI assets survive restarts. Set to 1 to force the
# container to re-seed `dist/` from its baked multi-stage cache on next boot
# (useful after upgrading the base image).
# FLUME_FORCE_DIST_SYNC=0

# ==========================================
# Gateway: adaptive ensemble & concurrency
# ==========================================
# Max concurrent requests the gateway will send to a single Ollama endpoint.
# When unset, the gateway derives a conservative value from detected CPU cores.
# FLUME_OLLAMA_MAX_CONCURRENT=
#
# System memory available to the gateway host in GiB. Used by the adaptive
# ensemble sizer to decide how many parallel LLM calls fit in VRAM/RAM. Leave
# unset on Mac laptops (auto-detected); set explicitly on Linux/Windows GPU
# hosts where the detection is conservative.
# FLUME_SYSTEM_MEMORY_GB=
#
# Fraction of system memory to reserve for the OS / other workloads (default
# 0.2 = 20% reserved, 80% usable for inference).
# FLUME_SYSTEM_RESERVED_FRACTION=0.2
#
# Disable the adaptive ensemble sizer and always use the configured size. Useful
# for deterministic tests or when you want full manual control.
# FLUME_ENSEMBLE_NO_ADAPTIVE=0

# ==========================================
# Worker manager: parallelism ceiling
# ==========================================
# Absolute ceiling on the number of worker processes the worker-manager will
# keep alive. Memory-based sizing may reduce this further.
# FLUME_MAX_PARALLEL=4
