{
  "index_patterns": ["agent-failure-records*"],
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "properties": {
      "id": {"type": "keyword"},
      "task_id": {"type": "keyword"},
      "error_class": {"type": "keyword"},
      "summary": {"type": "text"},
      "root_cause": {"type": "text"},
      "fix_applied": {"type": "text"},
      "created_at": {"type": "date"},
      "updated_at": {"type": "date"},
      "status": {"type": "keyword"},
      "severity": {"type": "keyword"},
      "related_ids": {"type": "keyword"},
      "tags": {"type": "keyword"}
    }
  }
}