{
  "index_patterns": ["agent-provenance-records*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "id": { "type": "keyword" },
        "task_id": { "type": "keyword" },
        "project": { "type": "keyword" },
        "repo": { "type": "keyword" },
        "agent_role": { "type": "keyword" },
        "context_refs": { "type": "keyword" },
        "tool_calls": { "type": "flattened" },
        "artifacts": { "type": "keyword" },
        "review_verdict": { "type": "keyword" },
        "created_at": { "type": "date" }
      }
    }
  }
}
