#!/usr/bin/env bash
# Flume CLI — Dashboard service + ChatGPT/Codex OAuth
#
# Usage:
#   flume start | stop | restart | status | enable | disable | logs
#   flume codex-oauth login | import | refresh | status

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLUME_ROOT="${SCRIPT_DIR}"
SERVICE_NAME="flume-dashboard"
UNIT_FILE="${HOME}/.config/systemd/user/${SERVICE_NAME}.service"

# Detect layout
if [ -f "${FLUME_ROOT}/install/setup/install-flume-service.sh" ]; then
    INSTALL_SCRIPT="${FLUME_ROOT}/install/setup/install-flume-service.sh"
elif [ -f "${FLUME_ROOT}/setup/install-flume-service.sh" ]; then
    INSTALL_SCRIPT="${FLUME_ROOT}/setup/install-flume-service.sh"
else
    INSTALL_SCRIPT=""
fi

# OAuth helpers (git: install/setup/… — package: setup/…)
_codex_oauth_py() {
    if [ -f "${FLUME_ROOT}/install/setup/codex_oauth_login.py" ]; then
        echo "${FLUME_ROOT}/install/setup/codex_oauth_login.py"
    elif [ -f "${FLUME_ROOT}/setup/codex_oauth_login.py" ]; then
        echo "${FLUME_ROOT}/setup/codex_oauth_login.py"
    fi
}

_openai_oauth_sh() {
    if [ -f "${FLUME_ROOT}/install/setup/openai-oauth.sh" ]; then
        echo "${FLUME_ROOT}/install/setup/openai-oauth.sh"
    elif [ -f "${FLUME_ROOT}/setup/openai-oauth.sh" ]; then
        echo "${FLUME_ROOT}/setup/openai-oauth.sh"
    fi
}

ensure_service_installed() {
    if [ ! -f "${UNIT_FILE}" ] && [ -n "${INSTALL_SCRIPT}" ]; then
        echo "Installing Flume dashboard service..."
        bash "${INSTALL_SCRIPT}"
        systemctl --user daemon-reload
    fi
}

cmd_start() {
    ensure_service_installed
    if [ ! -f "${UNIT_FILE}" ]; then
        echo "Error: Service not installed. Run setup.sh first."
        exit 1
    fi
    systemctl --user daemon-reload
    systemctl --user start "${SERVICE_NAME}"
    echo "Flume dashboard started."
    DASHBOARD_PORT=$(grep -E '^DASHBOARD_PORT=' "${FLUME_ROOT}/.env" 2>/dev/null | cut -d= -f2- || echo "8765")
    echo "Open http://localhost:${DASHBOARD_PORT}"
}

cmd_stop() {
    systemctl --user stop "${SERVICE_NAME}" 2>/dev/null || true
    echo "Flume dashboard stopped."
}

cmd_restart() {
    ensure_service_installed
    systemctl --user daemon-reload
    systemctl --user restart "${SERVICE_NAME}" 2>/dev/null || systemctl --user start "${SERVICE_NAME}"
    echo "Flume dashboard restarted."
}

cmd_status() {
    if [ ! -f "${UNIT_FILE}" ]; then
        echo "Service not installed. Run: ./flume start (or setup.sh)"
        exit 0
    fi
    systemctl --user status "${SERVICE_NAME}" 2>/dev/null || true
}

cmd_enable() {
    ensure_service_installed
    systemctl --user enable "${SERVICE_NAME}"
    echo "Flume dashboard will start on login."
}

cmd_disable() {
    systemctl --user disable "${SERVICE_NAME}" 2>/dev/null || true
    echo "Flume dashboard will not start on login."
}

cmd_logs() {
    journalctl --user -u "${SERVICE_NAME}" -f "${@}"
}

cmd_codex_oauth_help() {
    echo "ChatGPT / Codex OAuth for Flume (OpenAI provider, subscription session)"
    echo ""
    echo "Usage: flume codex-oauth <command>"
    echo ""
    echo "Commands:"
    echo "  login (default)  Device-code sign-in; writes .openai-oauth.json and updates .env"
    echo "  import           Import from official Codex CLI session (~/.codex/auth.json)"
    echo "  bootstrap        Try Codex cache then optional legacy profile import; refresh + .env"
    echo "  refresh          Refresh access token using saved refresh token"
    echo "  status           Show token metadata (secrets are not printed)"
    echo ""
    echo "After login or import: set Settings → LLM → OpenAI → OAuth, then:"
    echo "  flume restart"
    echo ""
}

cmd_codex_oauth() {
    local py sh
    py="$(_codex_oauth_py)"
    sh="$(_openai_oauth_sh)"
    local sub="${1:-login}"
    [ "$#" -ge 1 ] && shift || true

    case "${sub}" in
        help|-h|--help)
            cmd_codex_oauth_help
            ;;
        login)
            if [ -z "${py}" ] || [ ! -f "${py}" ]; then
                echo "Error: codex_oauth_login.py not found under ${FLUME_ROOT}."
                exit 1
            fi
            python3 "${py}" login --flume-root "${FLUME_ROOT}" "$@"
            ;;
        import|import-codex)
            if [ -z "${py}" ] || [ ! -f "${py}" ]; then
                echo "Error: codex_oauth_login.py not found under ${FLUME_ROOT}."
                exit 1
            fi
            python3 "${py}" import-codex --flume-root "${FLUME_ROOT}" "$@"
            ;;
        refresh|status|bootstrap)
            if [ -z "${sh}" ] || [ ! -f "${sh}" ]; then
                echo "Error: openai-oauth.sh not found under ${FLUME_ROOT}."
                exit 1
            fi
            bash "${sh}" "${sub}" "$@"
            ;;
        *)
            echo "Unknown codex-oauth command: ${sub}" >&2
            cmd_codex_oauth_help
            exit 1
            ;;
    esac
}

cmd_help() {
    echo "Flume CLI — Dashboard service and OAuth"
    echo ""
    echo "Usage: flume <command> [args...]"
    echo ""
    echo "Dashboard (systemd user service):"
    echo "  start     Start dashboard in background"
    echo "  stop      Stop dashboard"
    echo "  restart   Restart dashboard"
    echo "  status    Show dashboard status"
    echo "  enable    Start dashboard automatically on login"
    echo "  disable   Don't start dashboard on login"
    echo "  logs      Tail dashboard logs (journalctl -f)"
    echo ""
    echo "OpenAI ChatGPT / Codex OAuth:"
    echo "  codex-oauth [login|import|bootstrap|refresh|status]"
    echo "  Run \"flume codex-oauth help\" for details."
    echo ""
}

case "${1:-help}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    enable)  cmd_enable ;;
    disable) cmd_disable ;;
    logs)    shift; cmd_logs "$@" ;;
    codex-oauth)
        shift
        cmd_codex_oauth "$@"
        ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
