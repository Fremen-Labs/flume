# =============================================================================
# Flume Configuration
# =============================================================================
# Copy this file to .env in the Flume workspace root and fill in values.
# The install.sh script will guide you through this automatically.
# =============================================================================


# =============================================================================
# Elasticsearch
# =============================================================================

# URL of your Elasticsearch instance.
# If you ran the install-elasticsearch.sh setup script, use https://localhost:9200
ES_URL=https://localhost:9200

# API key for authenticating with Elasticsearch.
# install.sh auto-populates this from setup/install-elasticsearch.sh when available.
# If not auto-populated, add the key later from your secret store.
ES_API_KEY=AUTO_GENERATED_BY_INSTALLER

# Set to false if using self-signed TLS certs (default ES setup uses self-signed).
ES_VERIFY_TLS=false

# Elasticsearch index names (change only if you want custom index names).
ES_INDEX_TASKS=agent-task-records
ES_INDEX_HANDOFFS=agent-handoff-records
ES_INDEX_FAILURES=agent-failure-records
ES_INDEX_PROVENANCE=agent-provenance-records
ES_INDEX_MEMORY=agent-memory-entries


# =============================================================================
# Dashboard
# =============================================================================

# Network interface to listen on.
# Use 0.0.0.0 to accept connections from any interface, or 127.0.0.1 for localhost only.
DASHBOARD_HOST=0.0.0.0

# Port the dashboard HTTP server listens on.
DASHBOARD_PORT=8765


# =============================================================================
# LLM Provider
# =============================================================================
# Flume supports multiple LLM providers. Configure via Settings UI or edit here.
#
# Options: ollama | openai | anthropic | gemini | xai | mistral | cohere | openai_compatible
#
# For local/network routes (Ollama, custom endpoints):
#   LLM_BASE_URL — e.g. http://127.0.0.1:11434 (local) or http://10.0.0.50:1234 (network)
#
# For OpenAI OAuth (Codex-style): set OPENAI_OAUTH_STATE_FILE, leave LLM_API_KEY blank.
# =============================================================================

LLM_PROVIDER=ollama

# Base URL for the LLM endpoint.
#
#   ollama           : http://localhost:11434
#   openai           : leave blank (uses api.openai.com automatically)
#   openai_compatible: set to your provider's base URL, e.g.
#                        https://api.groq.com/openai
#                        https://api.together.xyz/v1
#                        https://api.mistral.ai
#   anthropic        : leave blank (uses api.anthropic.com automatically)
#   gemini           : leave blank (uses generativelanguage.googleapis.com automatically)
LLM_BASE_URL=http://localhost:11434

# API key — required for openai, anthropic, gemini, and most openai_compatible providers.
# Leave blank for local Ollama.
# For OpenAI OAuth users, you can keep this blank and run:
#   bash setup/openai-oauth.sh bootstrap
LLM_API_KEY=

# Optional: Flume can auto-refresh OpenAI OAuth access tokens from this state file
# when LLM_PROVIDER=openai and LLM_API_KEY is empty/expired.
OPENAI_OAUTH_STATE_FILE=.openai-oauth.json
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
# Optional: OAuth scopes for device login (codex-oauth login) + token refresh only — NOT browser authorize.
# Default includes model.request / api.responses.write. Set to empty to omit scope from those requests.
#OPENAI_OAUTH_SCOPES=
# Optional: scopes for login-browser / login-paste /oauth/authorize only (defaults to official Codex connector list).
# Do not put model.request here — OpenAI returns invalid_scope on authorize.
#OPENAI_OAUTH_AUTHORIZE_SCOPES=
# Optional: add resource=... to browser /oauth/authorize only (experimental).
# Do not rely on this for auth.openai.com — token refresh rejects parameter "resource".
#OPENAI_OAUTH_RESOURCE=https://api.openai.com

# Codex app-server (optional) — JSON-RPC agent surface; uses ~/.codex/auth.json like the Codex CLI.
# ./flume codex-app-server starts: codex app-server --listen <this URL>
#FLUME_CODEX_APP_SERVER_LISTEN=ws://127.0.0.1:4500
# Force npx instead of global codex: FLUME_CODEX_APP_SERVER_VIA_NPX=1
#CODEX_BIN=codex

# Model name to use. Examples by provider:
#   ollama           : llama3.2, mistral, codellama, qwen2.5-coder:14b
#   openai           : gpt-4o, gpt-4-turbo, gpt-4o-mini
#   openai_compatible: deepseek-r1-distill-llama-70b (Groq), meta-llama/Llama-3-70b (Together)
#   anthropic        : claude-opus-4-5, claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
#   gemini           : gemini-2.5-flash (default), gemini-2.5-flash-lite, gemini-2.5-pro (1.5/2.0 IDs are remapped)
LLM_MODEL=llama3.2


# =============================================================================
# GitHub Integration (optional)
# =============================================================================
# Required only if you want the dashboard to create GitHub Pull Requests.
# Store this in OpenBao and sync into Flume after installation.
GH_TOKEN=

# =============================================================================
# Azure DevOps (ADO) Integration (optional)
# =============================================================================
# Used when Flume needs to talk to Azure DevOps APIs (e.g. private repo / PRs).
# Store these in OpenBao and sync into Flume after installation.
# ADO_TOKEN — PAT
# ADO_ORG_URL — e.g. https://dev.azure.com/<org> (optional for now)
# =============================================================================
ADO_TOKEN=
ADO_ORG_URL=


# =============================================================================
# OpenBao (optional secret source)
# =============================================================================
# If using OpenBao, configure it here and keep runtime secrets there.
# Example:
# OPENBAO_ADDR=http://127.0.0.1:8200
# OPENBAO_TOKEN=
# OPENBAO_MOUNT=secret
# OPENBAO_PATH=flume
OPENBAO_ADDR=
OPENBAO_TOKEN=
OPENBAO_MOUNT=secret
OPENBAO_PATH=flume


# =============================================================================
# Git Identity (required for agent commits)
# =============================================================================
# These are applied globally to git config when agents commit code changes.
GIT_USER_NAME=FlumeAgent
GIT_USER_EMAIL=agent@flume.local


# =============================================================================
# Worker Manager
# =============================================================================

# Hostname or identifier for this machine.
# Used to filter which agent roles run on this host.
# Start worker manager + agent handlers when the dashboard starts (default: on).
# Set to 0 if you start workers manually or on another machine.
FLUME_AUTO_START_WORKERS=1

# Multiple machines can each run the worker-manager with different EXECUTION_HOST
# values to distribute agent roles across machines.
EXECUTION_HOST=localhost

# How often (in seconds) the worker manager polls Elasticsearch for new work.
WORKER_MANAGER_POLL_SECONDS=15
