{
  "index_patterns": ["agent-task-records*"],
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "default": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "stop"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": {"type": "keyword"},
      "title": {"type": "text"},
      "objective": {"type": "text"},
      "repo": {"type": "keyword"},
      "worktree": {"type": "keyword"},
      "item_type": {"type": "keyword"},
      "owner": {"type": "keyword"},
      "assigned_agent_role": {"type": "keyword"},
      "status": {"type": "keyword"},
      "priority": {"type": "keyword"},
      "depends_on": {"type": "keyword"},
      "acceptance_criteria": {"type": "text"},
      "artifacts": {"type": "text"},
      "needs_human": {"type": "boolean"},
      "risk": {"type": "keyword"},
      "created_at": {"type": "date"},
      "updated_at": {"type": "date"},
      "last_update": {"type": "date"},
      "commit_sha": {"type": "keyword"},
      "branch": {"type": "keyword"},
      "execution_host": {"type": "keyword"},
      "preferred_model": {"type": "keyword"},
      "active_worker": {"type": "keyword"},
      "agent_log": {
        "type": "nested",
        "properties": {
          "ts": {"type": "date"},
          "note": {"type": "text"}
        }
      }
    }
  }
}