{
  "index_patterns": ["agent-review-records*"],
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "dynamic": true,
    "properties": {
      "review_id": { "type": "keyword" },
      "task_id": { "type": "keyword" },
      "verdict": { "type": "keyword" },
      "summary": { "type": "text" },
      "issues": { "type": "text" },
      "recommended_next_role": { "type": "keyword" },
      "promotion_candidate": { "type": "boolean" },
      "confidence": { "type": "keyword" },
      "created_at": { "type": "date" }
    }
  }
}
